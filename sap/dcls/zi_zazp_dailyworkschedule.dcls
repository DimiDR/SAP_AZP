@EndUserText.label: 'AZP Access Control DailyWorkSchedule'
@MappingRole: true
define role ZI_ZAZP_DailyWorkSchedule {
  grant select on ZI_ZAZP_DailyWorkSchedule
    where ( ) = aspect pfcg_auth ( S_TABU_NAM, ACTVT = '03', TABLE = 'T550A' )
       or ( ) = aspect pfcg_auth ( S_TABU_DIS, ACTVT = '03', DICBERCLS = 'PC' );
}
